---
layout: null
sitemap: false
permalink: /admin/posts-data.json
---
[{% for post in site.posts %}{
  "index": {{ forloop.index }},
  "title": {{ post.title | jsonify }},
  "url": {{ post.url | relative_url | jsonify }},
  "slug": {{ post.slug | jsonify }},
  "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
  "dateDisplay": {{ post.date | date: "%b %-d, %Y" | jsonify }},
  "year": {{ post.date | date: "%Y" | jsonify }},
  "categories": {{ post.categories | jsonify }},
  "tags": {{ post.tags | jsonify }},
  "excerpt": {{ post.excerpt | strip_html | strip_newlines | truncate: 300 | jsonify }},
  "image": {{ post.image | jsonify | default: "null" }},
  {% assign _wc_space = post.content | number_of_words %}{% assign _wc_cjk = post.content | number_of_words: "cjk" %}{% assign _cjk_only = _wc_cjk | minus: _wc_space %}{% assign _cjk_eng = _cjk_only | times: 6 | divided_by: 10 %}{% assign _wc_equiv = _wc_space | plus: _cjk_eng %}"readingTime": {{ _wc_equiv | divided_by: 200 | at_least: 1 }},
  "wordCount": {{ _wc_equiv | default: 0 }},
  "titleLen": {{ post.title | size }},
  "excerptLen": {{ post.excerpt | strip_html | strip_newlines | strip | size }},
  "hasImage": {% if post.image %}true{% else %}false{% endif %},
  "hasBodyImage": {% if post.content contains '<img' %}true{% else %}false{% endif %},
  "charCount": {{ post.content | strip_html | strip_newlines | size | default: 0 }},
  "author": {{ post.author | jsonify | default: "null" }}
}{% unless forloop.last %},{% endunless %}{% endfor %}]
