---
layout: null
permalink: /search-index.json
sitemap: false
---
[{% for post in site.posts -%}
{%- if post.excerpt and post.excerpt != "" -%}
  {%- assign _body = post.excerpt | strip_html | strip_newlines | strip | truncate: 300 -%}
{%- else -%}
  {%- assign _body = post.content | strip_html | strip_newlines | strip | truncate: 300 -%}
{%- endif -%}
{"s":{{ post.slug | jsonify }},"t":{{ post.title | jsonify }},"u":{{ post.url | relative_url | jsonify }},"c":{{ post.categories | first | jsonify }},"g":{{ post.tags | join: " " | downcase | jsonify }},"b":{{ _body | downcase | jsonify }}}
{%- unless forloop.last %},{% endunless -%}
{% endfor %}]
